# Copiar este archivo a ".env" y ajustar los valores antes de levantar
# docker-compose. NUNCA commitear el archivo ".env" real.

# --- MySQL ---
MYSQL_ROOT_PASSWORD=changeme_root
MYSQL_DATABASE=biblioteca
MYSQL_USER=biblioteca_user
MYSQL_PASSWORD=changeme

# --- Backend ---
BACKEND_PORT=3001
DB_HOST=db
DB_PORT=3306
DB_USER=biblioteca_user
DB_PASSWORD=changeme
DB_NAME=biblioteca

# --- Frontend ---
FRONTEND_PORT=8080
# BACKEND_HOST/BACKEND_PORT no se listan aqui: el default de la imagen
# (backend:3001) ya coincide con el nombre del servicio "backend" de este
# docker-compose. Solo hace falta definirlas si el backend corriera con
# otro nombre de servicio u otro puerto.
